# Knowledge Navigator — copy to .env and fill in

# OpenAI (embeddings + chat Q&A + CRAG grading + query rewriting)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_GRADER_MODEL=gpt-4o-mini

# Optional
APP_NAME=knowledge-navigator
PORT=8000

# ----- Google OAuth (Sign in with Google) -----
# Create OAuth 2.0 credentials in Google Cloud Console (APIs & Services > Credentials).
# Add authorized redirect URI: http://localhost:8000/api/auth/callback (dev) or your backend URL in prod.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Where to send the user after login (must match frontend port: 3001 when using npm start).
FRONTEND_ORIGIN=http://localhost:3001

# Secret key for signing session JWTs. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=generate-a-long-random-string-here
